{
  "name": "agentic-ai-playwright-poc",
  "version": "1.0.0",
  "description": "Agentic AI framework: reads Jira stories, generates Playwright tests, pushes to GitHub, triggers CI/CD",
  "scripts": {
    "build": "tsc",
    "db:init": "ts-node --compiler-options '{\"module\":\"commonjs\"}' src/db/seed.ts",
    "agent": "ts-node --compiler-options '{\"module\":\"commonjs\"}' src/agent/index.ts",
    "test": "playwright test",
    "test:report": "playwright show-report",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "better-sqlite3": "^9.6.0",
    "dotenv": "^16.4.5",
    "octokit": "^3.1.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
