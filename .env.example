# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Jira / Atlassian ──────────────────────────────────────────
# Your Atlassian domain e.g. "mycompany" (not the full URL)
JIRA_HOST=mycompany.atlassian.net
JIRA_EMAIL=you@example.com
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=ATATT3...
# The Jira issue key the agent will read (e.g. PROJ-42)
JIRA_ISSUE_KEY=PROJ-1

# ── GitHub ────────────────────────────────────────────────────
# PAT with: repo, workflow scopes
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-github-username
GITHUB_REPO=agentic-ai-playwright-poc
GITHUB_BRANCH=agent/auto-tests

# ── SQLite ────────────────────────────────────────────────────
DB_PATH=./data/users.db
